{
  "name": "birdseye",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@react-three/fiber": "^9.6.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "expo": "~57.0.7",
    "expo-asset": "~57.0.6",
    "expo-camera": "~57.0.3",
    "expo-dev-client": "~57.0.7",
    "expo-file-system": "~57.0.1",
    "expo-gl": "~57.0.2",
    "expo-sensors": "~57.0.2",
    "expo-speech": "~57.0.1",
    "expo-status-bar": "~57.0.1",
    "express": "^5.2.1",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-webrtc": "^124.0.7",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@react-native/jest-preset": "^0.86.0",
    "@testing-library/react-native": "^14.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^26.1.1",
    "@types/react": "~19.2.2",
    "@types/three": "^0.185.1",
    "eslint": "^9.39.5",
    "eslint-config-expo": "^57.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^57.0.2",
    "jscpd": "^5.0.12",
    "react-test-renderer": "19.2.3",
    "tsx": "^4.23.1",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:integration": "jest --runInBand --testPathPatterns=integration",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "duplicates": "jscpd --threshold 0 --min-lines 8 --min-tokens 60 --format typescript,tsx --ignore \"**/*.test.ts,**/*.test.tsx,node_modules/**\" App.tsx src server",
    "build": "expo export --platform all"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "**/?(*.)+(test).[tj]s?(x)"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/integration/"
    ]
  },
  "private": true
}
