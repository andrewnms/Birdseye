{
  "name": "birdseye",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@react-three/fiber": "^9.6.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "expo": "^54.0.36",
    "expo-asset": "~12.0.13",
    "expo-audio": "~1.1.1",
    "expo-camera": "~17.0.10",
    "expo-dev-client": "~6.0.21",
    "expo-file-system": "~19.0.23",
    "expo-gl": "~16.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-sensors": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "express": "^5.2.1",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.12.1",
    "react-native-webrtc": "^124.0.7",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@testing-library/react-native": "^14.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^26.1.1",
    "@types/react": "~19.1.0",
    "@types/three": "^0.185.1",
    "eslint": "^9.39.5",
    "eslint-config-expo": "~10.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.12",
    "jscpd": "^5.0.12",
    "react-test-renderer": "19.1.0",
    "tsx": "^4.23.1",
    "typescript": "~5.9.2"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:integration": "jest --runInBand --testPathPatterns=integration",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "duplicates": "jscpd --threshold 0 --min-lines 8 --min-tokens 60 --format typescript,tsx --ignore \"**/*.test.ts,**/*.test.tsx,node_modules/**\" App.tsx src server",
    "build": "expo export --platform all"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "<rootDir>/jest-setup.js"
    ],
    "testMatch": [
      "**/?(*.)+(test).[tj]s?(x)"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/integration/"
    ]
  },
  "private": true
}
