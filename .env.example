# Use the Mac's Wi-Fi or hotspot IPv4 address, never localhost. This value is
# bundled into the development JavaScript and must not contain a secret.
EXPO_PUBLIC_API_URL=http://192.168.1.42:3000

# Used by the local Express process only. Never prefix this with EXPO_PUBLIC_.
OPENAI_API_KEY=replace-with-a-local-development-key

# The port exposed by the local Express process. It must match EXPO_PUBLIC_API_URL.
PORT=3000

# Optional local overrides. The defaults are gpt-realtime-2.1 and marin.
# OPENAI_REALTIME_MODEL=gpt-realtime-2.1
# OPENAI_REALTIME_VOICE=marin

# OPENAI_PLANNER_MODEL=gpt-5.6
